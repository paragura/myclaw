# myclaw - Environment Variables
# Copy this file to .env and fill in your values

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# AI API (OpenAI-compatible endpoint)
AI_API_URL=http://localhost:8888/v1/chat/completions
AI_MODEL=Qwen/Qwen3.6-35B-A3B-FP8
AI_API_KEY=dummy

# Database
DB_PATH=/tmp/myclaw.db
